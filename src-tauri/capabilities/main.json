{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-window",
  "description": "Capability set for the main application window. Only commands listed here are callable from the main window. Deny-by-inventory: any command not listed is blocked.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:app:allow-app-hide",
    "core:window:allow-start-dragging",
    "allow-get-active-surface",
    "allow-set-active-surface",
    "allow-chat-send",
    "allow-chat-cancel",
    "allow-artifact-get",
    "allow-artifact-dismiss",
    "allow-history-list",
    "allow-history-get",
    "allow-history-delete",
    "allow-history-search",
    "allow-privacy-set-provider-key",
    "allow-privacy-get-credential-status",
    "allow-privacy-clear-provider-key",
    "allow-files-open-dialog",
    "allow-files-read-token"
  ]
}
