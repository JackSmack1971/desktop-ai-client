{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/generate-codeowners/scripts/run_python.sh .claude/skills/generate-codeowners/scripts/hook_guard.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/generate-codeowners/scripts/run_python.sh .claude/skills/generate-codeowners/scripts/hook_completion.py --repo ."
          }
        ]
      }
    ]
  }
}
