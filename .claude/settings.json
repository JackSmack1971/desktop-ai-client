{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "version": 1,
  "description": "Claude Code settings for the desktop-ai-client scaffold.",
  "model": "sonnet",
  "disableSkillShellExecution": true,
  "disableBypassPermissionsMode": "disable",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log --oneline -20)",
      "Bash(git branch --show-current)",
      "Bash(node .claude/workflows/issue-to-pr.js:*)",
      "Bash(node .claude/workflows/review-readiness.js:*)",
      "Bash(node .claude/workflows/repo-audit.js:*)",
      "Bash(node .claude/workflows/audit-claude-context-compression.js:*)",
      "Bash(node .claude/workflows/release-readiness.js:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo fmt --check:*)",
      "Bash(cargo clippy:*)",
      "Bash(npm test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -m py_compile:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Bash(cat .env)",
      "Bash(type .env)",
      "Bash(cat .env.*)",
      "Bash(type .env.*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "Bash(del /f /s /q:*)",
      "Bash(terraform destroy:*)",
      "Bash(kubectl delete:*)",
      "Bash(dropdb:*)",
      "Read(./**/node_modules/**)",
      "Read(./**/.pnpm-store/**)",
      "Read(./**/.yarn/cache/**)",
      "Read(./**/.venv/**)",
      "Read(./**/venv/**)",
      "Read(./**/vendor/**)",
      "Read(./**/Pods/**)",
      "Read(./**/.bundle/**)",
      "Read(./**/dist/**)",
      "Read(./**/build/**)",
      "Read(./**/out/**)",
      "Read(./**/target/**)",
      "Read(./**/.next/**)",
      "Read(./**/.nuxt/**)",
      "Read(./**/.svelte-kit/**)",
      "Read(./**/.astro/**)",
      "Read(./**/.vite/**)",
      "Read(./**/.parcel-cache/**)",
      "Read(./**/.turbo/**)",
      "Read(./**/coverage/**)",
      "Read(./**/htmlcov/**)",
      "Read(./**/.gradle/**)",
      "Read(./**/.cache/**)",
      "Read(./**/.pytest_cache/**)",
      "Read(./**/.mypy_cache/**)",
      "Read(./**/.ruff_cache/**)",
      "Read(./**/.tox/**)",
      "Read(./**/.nox/**)",
      "Read(./**/__pycache__/**)",
      "Read(./**/*.min.js)",
      "Read(./**/*.min.css)",
      "Read(./**/*.map)",
      "Read(./**/*.log)"
    ]
  },
  "confirmations": {
    "dependencyChanges": true,
    "databaseMigrations": true,
    "publicApiChanges": true,
    "deployments": true
  },
  "tools": {
    "shell": {
      "enabled": true,
      "timeoutSeconds": 120
    },
    "git": {
      "protectBranches": [
        "main",
        "master"
      ],
      "requireStatusBeforeCommit": true
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-start.js",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-tool-use.js",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-tool-use.js",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/stop.js",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "claudeMdExcludes": [
    ".claude/worktrees/**"
  ]
}
