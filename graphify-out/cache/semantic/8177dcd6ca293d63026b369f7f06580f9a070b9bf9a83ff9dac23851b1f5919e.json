{"nodes": [{"id": "milestone_01_review_review_report", "label": "01-REVIEW: App Shell Code Review Report", "file_type": "document", "source_file": ".planning/milestones/v1.0-phases/01-app-shell/01-REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "milestone_01_review_cr_01_double_surfacerail", "label": "CR-01: Double SurfaceRail Render", "file_type": "rationale", "source_file": ".planning/milestones/v1.0-phases/01-app-shell/01-REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "+layout.svelte renders AppShell (which renders SurfaceRail) while +page.svelte renders WorkspaceShell (which also renders SurfaceRail), producing two navigation rails, two divergent focusedIndex states, and duplicate ARIA tablist landmarks."}, {"id": "milestone_01_review_cr_02_slot_vs_snippet", "label": "CR-02: Svelte 4 slot vs Svelte 5 snippet Mismatch", "file_type": "rationale", "source_file": ".planning/milestones/v1.0-phases/01-app-shell/01-REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "+layout.svelte used <slot /> (Svelte 4 API) while the rest of the codebase used {@render children?.()}; mixing these is undefined in Svelte 5 and results in a blank page body."}, {"id": "milestone_01_review_cr_03_race_condition", "label": "CR-03: Race Condition in get_active_surface", "file_type": "rationale", "source_file": ".planning/milestones/v1.0-phases/01-app-shell/01-REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Function read (current, hydrated) under one lock acquisition then released it; concurrent async invocations could both pass the !hydrated guard, causing duplicate DB reads and potential stale returns."}, {"id": "milestone_01_review_cr_04_sql_injection_precedent", "label": "CR-04: SQL Injection Precedent in Migration Savepoint", "file_type": "rationale", "source_file": ".planning/milestones/v1.0-phases/01-app-shell/01-REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Savepoint name and migration SQL assembled via format! string interpolation; not exploitable today (static constants) but sets a precedent future contributors might copy with dynamic content."}, {"id": "milestone_01_review_wr_01_duplicate_migration", "label": "WR-01: Duplicate schema_migrations Migration", "file_type": "rationale", "source_file": ".planning/milestones/v1.0-phases/01-app-shell/01-REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Inline bootstrap creates schema_migrations table, then MIGRATIONS slice 0001 repeats the same DDL, creating a confusing dual-creation path for incident diagnosis."}, {"id": "milestone_01_review_in_01_appshell_dead_component", "label": "IN-01: AppShell.svelte Dead/Superseded Component", "file_type": "rationale", "source_file": ".planning/milestones/v1.0-phases/01-app-shell/01-REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "AppShell.svelte is a strict subset of WorkspaceShell.svelte; leaving it in the tree risks future contributors reintroducing the double-rail bug."}, {"id": "milestone_01_review_in_02_surface_labels_duplication", "label": "IN-02: SURFACE_LABELS Duplicated Across Three Files", "file_type": "rationale", "source_file": ".planning/milestones/v1.0-phases/01-app-shell/01-REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Surface-to-string label mapping defined identically in surface.ts, WorkspaceShell.svelte, and +page.svelte, a future maintenance hazard if a new surface is added."}], "edges": [{"source": "milestone_01_r