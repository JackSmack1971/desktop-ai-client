{"nodes": [{"id": "codebase_architecture_architecture_doc", "label": "Architecture Document", "file_type": "document", "source_file": ".planning/codebase/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "codebase_architecture_layered_tauri_svelte_pattern", "label": "Layered Tauri/Svelte Desktop Client Pattern", "file_type": "rationale", "source_file": ".planning/codebase/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Backend owns all persistence, provider credentials, file authority, and routing decisions; renderer treated as potentially hostile surface with no secrets, raw paths, or SQL crossing the IPC boundary."}, {"id": "codebase_architecture_command_policy_authority", "label": "Single Command Policy Authority Pattern", "file_type": "rationale", "source_file": ".planning/codebase/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every IPC command validates window label and command-name membership through security::command_policy::policy_check before doing any work, replacing prior per-module duplicated checks."}, {"id": "codebase_architecture_six_source_inventory_reconciliation", "label": "Six-Source Command Inventory Reconciliation", "file_type": "rationale", "source_file": ".planning/codebase/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "ipc::inventory::verify_inventory() cross-checks command set against command-inventory.toml, registered handlers, permission files, capability files, release capabilities, and command_policy's own table to prevent drift."}, {"id": "codebase_architecture_opaque_file_token_pattern", "label": "Opaque File Token Pattern", "file_type": "rationale", "source_file": ".planning/codebase/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Raw file paths never exposed to renderer; security::file_tokens mints opaque tokens and the raw path stays backend-owned in AppState.file_tokens."}, {"id": "codebase_architecture_lock_ordering_invariant", "label": "Lock Ordering Invariant (shell before sqlite)", "file_type": "rationale", "source_file": ".planning/codebase/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "AppState fields guarded by Mutex<T>; shell lock must be acquired before sqlite lock (enforced in get_active_surface) to prevent deadlock across all callers."}], "edges": [{"source": "codebase_architecture_architecture_doc", "target": "codebase_architecture_layered_tauri_svelte_pattern", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".planning/codebase/ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "codebase_architecture_architecture_doc", "target": "codebase_architecture_command_policy_authority", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".planning/codebase/ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "codebase_architecture_architecture_doc", "target": "codebase_architecture_six_source_inventory_reconciliation", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".planning/codebase/ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "codebase_architecture_architecture_doc", "target": "codebase_architecture_opaque_file_token_pattern", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".planning/codebase/ARCHITECTURE.md", "source_location": null, "weight": 1.0}, {"source": "codebase_architecture_architecture_doc", "target": "codebase_architecture_lock_or